{
  "name": "rural-logistics-platform",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @rural/database prisma:generate",
    "db:migrate": "pnpm --filter @rural/database prisma:migrate",
    "db:seed": "pnpm --filter @rural/database prisma:seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.0.12",
    "typescript": "^5.5.4"
  }
}
